---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Cloud Solutions",
    description:
      "Expert guidance on cloud migration, architecture design, and optimization across AWS, Azure, and Google Cloud platforms.",
    icon: "bx:bxs-cloud",
  },
  {
    title: "Cloud Security",
    description:
      "Implement robust security measures for your cloud infrastructure with identity management, encryption, and compliance frameworks.",
    icon: "bx:bxs-lock",
  },
  {
    title: "Cybersecurity Assessment",
    description:
      "Comprehensive security audits, vulnerability assessments, and penetration testing to identify and mitigate risks.",
    icon: "bx:bxs-shield",
  },
  {
    title: "Network Infrastructure",
    description:
      "Design, deployment, and management of scalable network infrastructure tailored to your business requirements.",
    icon: "bx:bxs-server",
  },
  {
    title: "Security Operations",
    description:
      "24/7 security monitoring, incident response, and threat intelligence to protect your critical assets.",
    icon: "bx:bxs-lock-open",
  },
  {
    title: "IT Strategy & Planning",
    description:
      "Strategic technology roadmaps aligned with your business goals, ensuring sustainable growth and innovation.",
    icon: "bx:bxs-briefcase",
  },
];
---

<div class="mt-16 md:mt-0" id="services">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Comprehensive IT Services
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    From cloud infrastructure to cybersecurity, we provide end-to-end IT consulting services to help your business thrive in the digital age.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-black rounded-full  p-2 w-8 h-8 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>{" "}
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>
